---
import { SITE_INFO } from "../consts";
---

<header
  class="fixed top-0 w-full bg-slate-50/80 dark:bg-slate-900/80 backdrop-blur-md z-50 border-b border-slate-200 dark:border-slate-800"
>
  <div
    class="max-w-4xl mx-auto px-6 md:px-10 h-16 flex items-center justify-between"
  >
    <a
      href="/"
      class="font-bold text-xl text-slate-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
    >
      {SITE_INFO.name}.
    </a>
    <nav>
      <ul
        class="flex gap-4 md:gap-6 text-sm font-medium text-slate-600 dark:text-slate-300"
      >
        <li>
          <a
            href="/proyectos"
            class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
          >
            Proyectos
          </a>
        </li>
        <li>
          <a
            href="/sobre-mi"
            class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
          >
            Sobre mí
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>
