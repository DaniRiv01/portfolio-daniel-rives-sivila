---
interface Props {
  titulo: string;
  descripcion: string;
  tags: string[];
  imagen: string;
  enlace: string;
  nuevaPestana?: boolean;
}
const { titulo, descripcion, tags, imagen, enlace, nuevaPestana } = Astro.props;

const tagColors: Record<string, string> = {
  "Proyectos": "bg-blue-100 text-blue-700 dark:bg-blue-500/20 dark:text-blue-300 border border-blue-200 dark:border-blue-500/30",
  "Juegos": "bg-purple-100 text-purple-700 dark:bg-purple-500/20 dark:text-purple-300 border border-purple-200 dark:border-purple-500/30",
  "Astro": "bg-orange-100 text-orange-700 dark:bg-orange-500/20 dark:text-orange-300 border border-orange-200 dark:border-orange-500/30",
  "Anime": "bg-pink-100 text-pink-700 dark:bg-pink-500/20 dark:text-pink-300 border border-pink-200 dark:border-pink-500/30",
  "default": "bg-slate-100 text-slate-700 dark:bg-slate-700/50 dark:text-slate-300 border border-slate-200 dark:border-slate-600"
};
---

<article class="flex flex-col md:flex-row gap-6 p-4 md:p-6 rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-800/50 hover:border-blue-500 transition-colors group overflow-hidden">
  
  <div class="w-full md:w-1/3 aspect-video rounded-xl overflow-hidden shrink-0">
    <img
      src={imagen}
      alt={`Imagen del proyecto ${titulo}`}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
    />
  </div>

  <div class="w-full md:w-2/3 flex flex-col justify-center">
    <h3 class="text-2xl font-semibold mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
      {titulo}
    </h3>

    <p class="text-slate-600 dark:text-slate-400 mb-4 line-clamp-3">
      {descripcion}
    </p>

    <ul class="flex flex-wrap gap-2 mb-4">
      {tags.map((tag) => {
        const tagUrl = tag.toLowerCase(); 

        return (
          <li>
            <a 
              href={`/blog/${tagUrl}`} 
              class={`inline-block px-3 py-1 text-xs font-semibold rounded-full shadow-sm hover:scale-105 transition-transform ${tagColors[tag] || tagColors["default"]}`}
              title={`Leer más sobre ${tag}`}
            >
              {tag}
            </a>
          </li>
        );
      })}
    </ul>

    <div class="mt-auto pt-2">
      <a
        href={enlace}
        target={nuevaPestana ? "_blank" : "_self"}
        rel={nuevaPestana ? "noopener noreferrer" : ""}
        class="text-blue-600 dark:text-blue-400 font-medium hover:underline inline-flex items-center gap-1"
      >
        Ver proyecto <span class="text-lg">→</span>
      </a>
    </div>
  </div>
</article>