---
import Layout from "../../layouts/Layout.astro";
import { tematicas } from "../../data/tematicas";
import { SITE_INFO } from "../../consts";
---

<Layout 
  title={`Blog y Temáticas | ${SITE_INFO.name}`} 
  description="Mi rincón personal donde hablo de proyectos, juegos, tecnologías y aficiones."
>
  <section class="mt-24 md:mt-32 max-w-5xl mx-auto reveal mb-20 px-4">
    <a href="/portfolio-daniel-rives-sivila/" class="text-blue-600 dark:text-blue-400 hover:underline mb-8 inline-flex items-center gap-2 font-medium">
      <span class="text-xl">←</span> Volver al inicio
    </a>

    <div class="mb-12 border-b border-slate-200 dark:border-slate-800 pb-10">
      <h1 class="text-5xl md:text-6xl font-extrabold text-slate-900 dark:text-white mb-6 tracking-tight">
        Mi <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-500">Blog</span> Personal
      </h1>
      <p class="text-xl text-slate-600 dark:text-slate-400 max-w-3xl leading-relaxed">
        Un espacio dedicado a profundizar en mi experiencia como desarrollador junior, mis opiniones sobre videojuegos y las aficiones que inspiran mi lado más creativo.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {tematicas.map((tema) => (
        <a 
          href={`/portfolio-daniel-rives-sivila/blog/${tema.id}`} 
          class="group block rounded-3xl bg-white/40 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700/50 hover:border-blue-500 dark:hover:border-blue-500 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 overflow-hidden"
        >
          <div class="overflow-hidden" style="aspect-ratio: 2 / 1;">
            <img 
              src={tema.imagenHeader} 
              alt={`Imagen de cabecera para ${tema.nombre}`} 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-6 md:p-8">
            
            <div class="flex flex-col-reverse sm:flex-row sm:items-center justify-between mb-4 gap-3 sm:gap-4">
              <h2 class="text-2xl font-bold text-slate-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                {tema.nombre}
              </h2>
              <span class="w-fit px-3 py-1 text-xs font-semibold rounded-full bg-slate-100 text-slate-700 dark:bg-slate-700 dark:text-slate-300 shrink-0">
                {tema.tipo}
              </span>
            </div>

            <p class="text-slate-600 dark:text-slate-400 line-clamp-3 mb-6 leading-relaxed">
              {tema.resumen}
            </p>
            <div class="text-sm font-medium text-blue-600 dark:text-blue-400 flex items-center gap-1 group-hover:underline">
              Leer artículo <span class="text-lg leading-none transition-transform group-hover:translate-x-1">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>