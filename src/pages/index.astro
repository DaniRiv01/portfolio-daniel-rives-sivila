---
import Layout from "../layouts/Layout.astro";
import ProyectoCard from "../components/ProyectoCard.astro";
import { SITE_INFO, SKILLS } from "../consts";
import { proyectos } from "../data/proyectos";
import TechTags from "../components/TechTags.astro";

const proyectosDestacados = proyectos.slice(0, 3);
---

<Layout
  title={`${SITE_INFO.name} | Inicio`}
  description={SITE_INFO.description}
>
  <section class="reveal mt-16 md:mt-0">
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
      ¡Hola! Soy <span class="text-blue-600 dark:text-blue-400"
        >{SITE_INFO.name}</span
      >
    </h1>
  </section>

  <section id="sobre-mi" class="mt-24 md:mt-40 scroll-mt-24">
    <h2 class="reveal text-4xl font-bold mb-8 text-slate-900 dark:text-white">
      Sobre mí
    </h2>

    <div class="reveal flex flex-col-reverse md:flex-row gap-10 items-center">
      <div
        class="w-full md:w-2/3 space-y-4 text-lg text-slate-600 dark:text-slate-300"
      >
        <p>
          ¡Hola! Soy un desarrollador web apasionado por crear interfaces
          limpias, rápidas y accesibles. Me encanta transformar problemas
          complejos en soluciones digitales sencillas y elegantes.
        </p>
        <p>
          Me especializo en transformar problemas enrevesados en soluciones que
          parecen sencillas a simple vista. Creo firmemente que una web debe ser <strong
            >limpia, rápida y, sobre todo, accesible</strong
          > para cualquier persona que la visite.
        </p>
        <p class="pt-2">
          Si quieres profundizar en mi trayectoria y ver cómo he llegado hasta
          aquí, haz click <a
            href="/sobre-mi"
            class="text-blue-600 dark:text-blue-400 font-bold hover:underline"
            >aquí</a
          >.
        </p>
      </div>

      <div
        class="w-48 h-48 md:w-64 md:h-64 shrink-0 rounded-full overflow-hidden border-4 border-white dark:border-slate-800 shadow-lg"
      >
        <img
          src="/sobre-mi/Velotibu.jpg"
          alt="Foto de perfil de Tu Nombre"
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  </section>

  <section class="reveal mt-24 md:mt-40 mb-20">
    <h3 class="text-4xl font-bold mb-6 text-slate-900 dark:text-white">
      Tecnologías y Herramientas
    </h3>

    <p
      class="text-base md:text-lg text-slate-600 dark:text-slate-400 mb-8 max-w-2xl leading-relaxed"
    >
      Aunque mi fuerte es construir arquitecturas sólidas en el <span
        class="text-blue-600 dark:text-blue-400 font-semibold">Backend</span
      >, disfruto dominando las herramientas que dan vida a la interfaz.
      Este es el ecosistema que utilizo para crear soluciones completas:
    </p>

    <TechTags />

  </section>

  <section id="proyectos" class="reveal mt-20 md:mt-32">
    <h2 class="text-4xl font-bold mb-8 text-slate-900 dark:text-white">
      Proyectos Destacados
    </h2>

    <div class="grid grid-cols-1 gap-8">
      {
        proyectosDestacados.map((proyecto) => (
          <div class="reveal">
            <ProyectoCard {...proyecto} />
          </div>
        ))
      }
    </div>

    <a
      href="/proyectos"
      class="flex justify-center w-full mt-10 text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 font-medium transition-colors"
    >
      Ver más proyectos <span class="ml-1 text-lg">↓</span>
    </a>
  </section>
</Layout>
